# PaymentService - copy to .env and set your values.
# docker-compose and `make up` read .env automatically. Do not commit .env.

# --- Splunk Observability (required for otel-collector to send data) ---
SPLUNK_ACCESS_TOKEN=
SPLUNK_REALM=sg0

# --- AppDynamics (optional; leave empty to run without AppD agent) ---
# APPD_AGENT_JAR=/app/agents/javaagent.jar
# Or any path, e.g. /app/agents/ver26.2.0.37684/javaagent.jar. Default: agents/javaagent.jar or first agents/ver*/javaagent.jar
APPD_CONTROLLER_HOST=
APPD_ACCOUNT_NAME=
APPD_ACCOUNT_ACCESS_KEY=
# APPD_CONTROLLER_PORT=443
# APPD_CONTROLLER_SSL=true
# APPD_APP_NAME=payment-space
# APPD_TIER_NAME=PaymentService
# APPD_NODE_NAME=PaymentNode

# --- Optional ---
# HOST_NAME=payment-service-host
