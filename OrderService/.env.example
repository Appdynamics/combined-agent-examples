# Splunk Observability Cloud (collector)
SPLUNK_ACCESS_TOKEN=your-splunk-access-token
SPLUNK_REALM=sg0

# Host name for collector resource attributes (hostmetrics)
HOST_NAME=order-service-host

# AppDynamics (optional; leave empty for Splunk-only)
APPD_CONTROLLER_HOST=
APPD_CONTROLLER_PORT=443
APPD_ACCOUNT_NAME=
APPD_ACCOUNT_ACCESS_KEY=
APPD_APP_NAME=order-space
APPD_TIER_NAME=OrderService
APPD_NODE_NAME=OrderNode

# Service identity
SERVICE_NAME=OrderService

# Always-on profiling (CPU + memory). Enable: SPLUNK_PROFILER_ENABLED=true, SPLUNK_PROFILER_MEMORY_ENABLED=true
SPLUNK_PROFILER_ENABLED=false
SPLUNK_PROFILER_MEMORY_ENABLED=false
SPLUNK_PROFILER_CALL_STACK_INTERVAL=1000
