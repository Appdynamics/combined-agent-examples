{
  "name": "order-service",
  "version": "1.0.0",
  "description": "Simple Order Service for AppDynamics demonstration",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "docker:build": "docker build -t order-service .",
    "docker:run": "docker run -d --name order-service -p 3000:3000 order-service",
    "docker:stop": "docker stop order-service && docker rm order-service",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "orders",
    "appdynamics",
    "demo"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@splunk/otel": "^3.3.0",
    "appdynamics": "^25.12.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
